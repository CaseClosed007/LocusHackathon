# ── Google Gemini ──────────────────────────────────────────────────────
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# ── Locus PaaS ────────────────────────────────────────────────────────
# Get from: app.paywithlocus.com → Settings → API Keys
LOCUS_API_KEY=claw_your_key_here

# Beta users: override these two lines
# LOCUS_BUILD_API=https://beta-api.buildwithlocus.com/v1
# LOCUS_GIT_HOST=https://beta-git.buildwithlocus.com

# Route LLM calls through Locus payment rails (true) or direct Gemini (false)
USE_LOCUS_WRAPPED=false

# ── GitHub (optional) ─────────────────────────────────────────────────
# Without token: 60 req/hr  |  With token: 5000 req/hr
# Get from: github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=

# ── Server ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
